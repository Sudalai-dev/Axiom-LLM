# Byte-compiled / optimized / DLL files
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Databases
*.db
*.sqlite

# Environments
.env
.env.local
.env.*
venv/
.venv/
env/
ENV/

# Pytest
.pytest_cache/

# IDE / Editor
.claude/

# PID files
*.pid

# Generated datasets — regenerable via `python -m datasets.generator`; not read
# at runtime (only datasets/*.py code is). Kept out of version control so large,
# machine-generated corpora don't bloat the repo or drift from the generator.
datasets/*/data.json
datasets/*/data.jsonl
datasets/*/data.csv
datasets/metadata/generation_report.json

# OS files
Thumbs.db
.DS_Store
